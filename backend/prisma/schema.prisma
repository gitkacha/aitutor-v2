generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Tenancy (Milestone 2) ───────────────────────────────────────────────────
// A Workspace is the tenant container. Curriculum (types, topics, question banks)
// stays global; attempts, analyses, worksheets and assignments are tenant-scoped.

model Workspace {
  id             Int             @id @default(autoincrement())
  name           String
  slug           String          @unique
  isDemo         Boolean         @default(false)
  users          User[]
  worksheets     Worksheet[]
  mathWorksheets MathWorksheet[]
}

model User {
  id              Int     @id @default(autoincrement())
  workspaceId     Int
  role            String // 'admin' | 'student'
  name            String
  email           String  @unique
  // The IdP-swap seam: an external-IdP user has authProvider 'oidc', a
  // providerSubject (the sub claim) and no passwordHash.
  authProvider    String  @default("local")
  providerSubject String?
  passwordHash    String?
  // Cross-workspace platform capability (W-15): can create workspaces + their first
  // admin and view any workspace read-only. Orthogonal to `role`.
  isSuperAdmin    Boolean @default(false)
  isDemo          Boolean @default(false)
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  attempts        Attempt[]
  mathAttempts    MathAttempt[]
  createdWorksheets        Worksheet[]               @relation("WorksheetCreator")
  createdMathWorksheets    MathWorksheet[]           @relation("MathWorksheetCreator")
  worksheetAssignments     WorksheetAssignment[]
  mathWorksheetAssignments MathWorksheetAssignment[]
}

model WorksheetAssignment {
  id          Int       @id @default(autoincrement())
  worksheetId Int
  studentId   Int
  createdAt   DateTime  @default(now())
  worksheet   Worksheet @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
  student     User      @relation(fields: [studentId], references: [id])

  @@unique([worksheetId, studentId])
}

model MathWorksheetAssignment {
  id          Int           @id @default(autoincrement())
  worksheetId Int
  studentId   Int
  createdAt   DateTime      @default(now())
  worksheet   MathWorksheet @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
  student     User          @relation(fields: [studentId], references: [id])

  @@unique([worksheetId, studentId])
}

model WritingType {
  id                Int       @id @default(autoincrement())
  name              String
  slug              String    @unique
  description       String
  expectedStructure String
  isDemo            Boolean   @default(false)
  prompts           Prompt[]
  attempts          Attempt[]
}

model Prompt {
  id        Int       @id @default(autoincrement())
  text      String
  typeId    Int
  // 'bank' = seeded practice prompt; 'worksheet' = created for a saved worksheet so
  // attempts and analysis reference the task the student actually answered (H4).
  source    String    @default("bank")
  isDemo    Boolean   @default(false)
  type      WritingType @relation(fields: [typeId], references: [id])
  attempts  Attempt[]
}

model Attempt {
  id          Int       @id @default(autoincrement())
  userId      Int
  typeId      Int
  promptId    Int
  text        String
  startedAt   DateTime
  finishedAt  DateTime
  timeTaken   Int
  source      String
  worksheetId Int?
  isDemo      Boolean   @default(false)
  user        User        @relation(fields: [userId], references: [id])
  type        WritingType @relation(fields: [typeId], references: [id])
  prompt      Prompt      @relation(fields: [promptId], references: [id])
  worksheet   Worksheet?  @relation(fields: [worksheetId], references: [id])
  analysis    Analysis?
}

model Analysis {
  id                Int     @id @default(autoincrement())
  attemptId         Int     @unique
  vocabScore        Int
  vocabComments     String
  structureScore    Int
  structureComments String
  contentScore      Int
  contentComments   String
  overallScore      Int
  summary           String
  criteriaScores    String?
  isDemo            Boolean @default(false)
  attempt           Attempt @relation(fields: [attemptId], references: [id])
}

model Worksheet {
  id          Int       @id @default(autoincrement())
  workspaceId Int
  createdById Int
  title       String
  typeId      Int
  prompts     String
  createdAt   DateTime  @default(now())
  isDemo      Boolean   @default(false)
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdBy   User      @relation("WorksheetCreator", fields: [createdById], references: [id])
  attempts    Attempt[]
  assignments WorksheetAssignment[]
}

// ── Mathematics Models ──────────────────────────────────────────────────────

model MathTopic {
  id          Int            @id @default(autoincrement())
  name        String
  slug        String         @unique
  description String
  isDemo      Boolean        @default(false)
  skills      Skill[]
  questions   MathQuestion[]
  attempts    MathAttempt[]
}

model MathStimulusGroup {
  id        Int            @id @default(autoincrement())
  stimulus  String
  questions MathQuestion[]
}

model Skill {
  id             Int     @id @default(autoincrement())
  subject        String  // 'math' | 'writing'
  topicId        Int?
  name           String
  slug           String  @unique
  description    String
  examLevelNotes String
  isDemo         Boolean @default(false)
  topic          MathTopic?     @relation(fields: [topicId], references: [id])
  questions      MathQuestion[]
}

model MathQuestion {
  id              Int                @id @default(autoincrement())
  topicId         Int
  stimulusGroupId Int?
  worksheetId     Int?
  skillId         Int?
  questionText    String
  options         String
  correctIndex    Int
  explanation     String
  percentCorrect  Float?
  isDemo          Boolean            @default(false)
  topic           MathTopic          @relation(fields: [topicId], references: [id])
  stimulusGroup   MathStimulusGroup? @relation(fields: [stimulusGroupId], references: [id])
  // A worksheet's persisted questions die with it — SET NULL would promote them into
  // the `worksheetId: null` topic practice banks (H5).
  worksheet       MathWorksheet?     @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
  skill           Skill?             @relation(fields: [skillId], references: [id])
}

model MathAttempt {
  id             Int            @id @default(autoincrement())
  userId         Int
  topicId        Int?
  questions      String
  answers        String
  topicBreakdown String
  score          Int
  totalQuestions Int
  startedAt      DateTime
  finishedAt     DateTime
  timeTaken      Int
  source         String
  worksheetId    Int?
  questionTimings String?
  questionFlags  String?
  answerChanges  String?
  isDemo         Boolean        @default(false)
  user           User           @relation(fields: [userId], references: [id])
  topic          MathTopic?     @relation(fields: [topicId], references: [id])
  worksheet      MathWorksheet? @relation(fields: [worksheetId], references: [id])
}

model MathWorksheet {
  id           Int            @id @default(autoincrement())
  workspaceId  Int
  createdById  Int
  title        String
  topicIds     String
  questions    String
  createdAt    DateTime       @default(now())
  isDemo       Boolean        @default(false)
  workspace    Workspace      @relation(fields: [workspaceId], references: [id])
  createdBy    User           @relation("MathWorksheetCreator", fields: [createdById], references: [id])
  attempts     MathAttempt[]
  questionRows MathQuestion[]
  assignments  MathWorksheetAssignment[]
}